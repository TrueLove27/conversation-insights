# Talksmith / conversation-insights environment

# Database
# DATABASE_PATH=data/conversation_insights.db

# Ingestion auth
# INGEST_API_KEY=dev-ingest-key-change-me
# WEBHOOK_SECRET=

# Groq LLM (optional — falls back to rule-based analysis)
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile
# ENABLE_LLM_ANALYSIS=true

# RAG / corpus platform services
# RAG_SERVICE_URL=http://localhost:8002
# CORPUS_SERVICE_URL=http://localhost:8004
ENABLE_RAG_CONTEXT=true

# Rate limits
# RATE_LIMIT_DEFAULT=120/minute
# RATE_LIMIT_ANALYZE=20/minute
# RATE_LIMIT_INGEST=40/minute

# Debug logging
# DEBUG=false
